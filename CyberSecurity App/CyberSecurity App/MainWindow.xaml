<Window x:Class="CyberSecurityApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔒 Cybersecurity Chatbot"
        Height="700"
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#075E54" Padding="15,20,15,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🛡️" FontSize="24" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Margin="10,0">
                    <TextBlock Text="Cyber Security Bot" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock x:Name="statusText" 
                               Text="● Online" 
                               FontSize="11" 
                               Foreground="#25D366"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="btnVoice" 
                            Content="🔊" 
                            Background="Transparent" 
                            BorderThickness="0"
                            Foreground="White"
                            FontSize="18"
                            Cursor="Hand"
                            Width="35"
                            Click="ToggleVoice_Click"/>
                    <Button x:Name="btnClear" 
                            Content="🗑️" 
                            Background="Transparent" 
                            BorderThickness="0"
                            Foreground="White"
                            FontSize="16"
                            Cursor="Hand"
                            Width="35"
                            Click="ClearChat_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Chat Area -->
        <ScrollViewer Grid.Row="1" 
                      x:Name="chatScrollViewer"
                      Background="#ECE5DD"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="chatPanel" 
                        Margin="10"
                        VerticalAlignment="Bottom"/>
        </ScrollViewer>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        x:Name="btnMenu"
                        Content="⚡" 
                        Background="#075E54" 
                        Foreground="White"
                        BorderThickness="0"
                        Width="42"
                        Height="42"
                        FontSize="20"
                        Cursor="Hand"
                        Click="ShowQuickMenu_Click"/>

                <TextBox x:Name="messageBox"
                         Grid.Column="1"
                         Height="40"
                         FontSize="14"
                         Background="White"
                         Foreground="#111B21"
                         BorderBrush="#E0E0E0"
                         BorderThickness="1"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         Margin="8,0"
                         KeyDown="MessageBox_KeyDown"/>

                <Button Grid.Column="2" 
                        x:Name="btnSend"
                        Content="📤" 
                        Background="#25D366" 
                        Foreground="White"
                        BorderThickness="0"
                        Width="42"
                        Height="42"
                        FontSize="18"
                        Cursor="Hand"
                        Click="SendMessage_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>